# ============================================================
# CARA environment — copy this file to ".env" and fill it in.
# ".env" is gitignored; never commit real secrets.
# Generate strong values:  python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# ============================================================

# --- Admin login (created on first run if no admin exists; change later in the admin panel) ---
CARA_ADMIN_USERNAME=admin
CARA_ADMIN_PASSWORD=set-a-strong-password

# --- Session signing key: signs admin sessions + print-link tokens. MUST be strong + secret. ---
#   python3 -c "import secrets; print(secrets.token_hex(32))"
CARA_SECRET_KEY=generate-a-long-random-hex-string

# --- Fernet key for encrypting stored SaaS credentials at rest ---
# Leave blank to auto-generate & persist to data/cara/secret.key on first run, or:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CARA_FERNET_KEY=

# --- Embedding model used by the backend for document RAG (fastembed) ---
CARA_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Support contact shown in the admin UI (who staff contact for help) ---
CARA_SUPPORT_CONTACT=

# --- Timezone for "today / this week / overdue" date logic ---
CARA_TIMEZONE=America/Chicago

# --- LLM wiring -------------------------------------------------------------
# Open WebUI talks to the CARA proxy (auto thinking/non-thinking routing + per-mode params);
# the proxy forwards to LM Studio at CARA_LLM_UPSTREAM.
OPENAI_API_BASE_URL=http://cara-backend:8000/llm/v1
# Open WebUI sends this as its Bearer to the proxy; it MUST equal CARA_LLM_PROXY_KEY.
OPENAI_API_KEY=set-equal-to-CARA_LLM_PROXY_KEY
CARA_LLM_UPSTREAM=http://host.docker.internal:1234/v1
# Require this Bearer on the /llm proxy so the LLM isn't open on the network. Strong + secret.
CARA_LLM_PROXY_KEY=generate-a-strong-token

# --- Bearer token required by the /tools OpenAPI server (set the SAME value in Open WebUI's
#     tool-server auth). Strong + secret. ---
CARA_TOOLS_TOKEN=generate-a-strong-token

# --- Public URLs ------------------------------------------------------------
# Browser-reachable base URL of the backend (for printable PDF links) and of Open WebUI.
# For LAN access, make cara.local resolve to the CARA Mac's
# reserved IP. Direct IP access also works because Docker publishes the ports on 0.0.0.0.
CARA_PUBLIC_BASE_URL=http://cara.local:8000
WEBUI_URL=http://cara.local:3000
