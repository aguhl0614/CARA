# ============================================================
# CARA environment — copy this file to ".env" and fill it in.
# ".env" is gitignored; never commit real secrets.
# ============================================================

# --- Admin login (created on first run if no admin exists) ---
CARA_ADMIN_USERNAME=admin
CARA_ADMIN_PASSWORD=change-me-now

# --- Session signing key (any long random string) ---
CARA_SECRET_KEY=please-generate-a-long-random-string

# --- Fernet key for encrypting stored SaaS credentials at rest ---
# Leave blank to auto-generate & persist to data/cara/secret.key on first run,
# or generate one explicitly:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CARA_FERNET_KEY=

# --- Embedding model used by the backend for document RAG (fastembed) ---
CARA_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Support contact shown in the admin UI (who staff contact for help) ---
CARA_SUPPORT_CONTACT=

# --- Open WebUI -> LM Studio (host app). Can also be set in the Open WebUI UI. ---
# host.docker.internal points containers at the host Mac where LM Studio runs.
OPENAI_API_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_API_KEY=lm-studio
